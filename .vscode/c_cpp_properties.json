{
  "configurations": [
    {
      "name": "AVR",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/lib/avr/include",
        "/usr/lib/gcc/avr/*/include"
      ],
      "defines": [
        "F_CPU=16000000UL",
        "__AVR_ATmega328P__"
      ],
      "compilerPath": "/usr/bin/avr-gcc",
      "compilerArgs": [
        "-mmcu=atmega328p"
      ],
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "gcc-x86"
    }
  ],
  "version": 4
}